<%- include("partials/header", { title }) %>

<div class="page-content">
  <h2>Upcoming Service Projects</h2>

  <div class="card">
    <% if (projects && projects.length > 0) { %>
      <ul>
        <% projects.forEach(project => { %>
          <li>
            <a href="/project/<%= project.project_id %>"><%= project.title %></a>
            -
            <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p>No upcoming projects found.</p>
    <% } %>
  </div>
</div>

<%- include("partials/footer", { currentYear }) %>
